<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>פאנל ניהול | עומר טייכר</title>
<link href="https://fonts.googleapis.com/css2?family=Rubik:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/admin/admin-style.css">
</head>
<body>

<div id="token-gate">
  <div style="font-size:1.3rem;font-weight:800;color:#fff;font-family:'Rubik',sans-serif;">עומר <span style="color:var(--orange)">טייכר</span> — פאנל ניהול</div>
  <div class="token-box">
    <h2>הכנס GitHub Token</h2>
    <p>נשמר אצלך במכשיר בלבד</p>
    <input type="text" name="username" autocomplete="username" value="admin" style="display:none;">
    <input class="token-input" id="token-input" type="password" placeholder="ghp_..." autocomplete="current-password" onkeydown="if(event.key==='Enter')saveToken()">
    <button class="token-btn" onclick="saveToken()">כניסה</button>
  </div>
</div>

<div id="main-content">
  <div class="header">
    <div class="header-logo">עומר <span>טייכר</span></div>
    <div class="header-right">
      <div class="tabs">
        <button class="tab-btn active" onclick="switchTab('content')">📝 תוכן</button>
        <button class="tab-btn" onclick="switchTab('code')">💻 קוד</button>
        <button class="tab-btn" onclick="switchTab('backups')">🔄 גיבויים</button>
      </div>
      <div class="repo-switcher" id="repo-switcher">
        <div class="repo-current" onclick="toggleRepoDropdown()">
          <span id="repo-label">🌐 אתר ראשי</span>
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
        </div>
        <div class="repo-dropdown" id="repo-dropdown">
          <div class="repo-option active" onclick="selectRepo('omer-taicher-site','🌐 אתר ראשי')">🌐 אתר ראשי</div>
          <div class="repo-option" onclick="selectRepo('omer-taicher-tutorials','🎓 הדרכות')">🎓 הדרכות</div>
        </div>
      </div>
      <button class="save-btn" id="save-content-btn" onclick="saveContent()" disabled>
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
        שמור ופרסם
      </button>
    </div>
  </div>

  <!-- TAB: CONTENT -->
  <div class="tab-panel active" id="tab-content">
    <div class="status-bar">
      <div class="status-dot loading" id="status-dot-content"></div>
      <div class="status-text" id="status-text-content">טוען תוכן...</div>
    </div>
    <div class="section-block open" id="block-hero">
      <div class="section-head" onclick="toggleBlock('hero')"><div class="section-head-left"><div class="section-icon">🏠</div><div><div class="section-name">הירו</div><div class="section-count">כותרת, טקסט, ציטוט</div></div></div><div class="chevron">▼</div></div>
      <div class="section-body">
        <div class="fields-row"><div class="field"><label class="field-label">כותרת שורה 1</label><input type="text" id="hero.title_1"></div><div class="field"><label class="field-label">כותרת שורה 2</label><input type="text" id="hero.title_2"></div></div>
        <div class="field"><label class="field-label">טקסט פתיחה</label><textarea id="hero.lead_1"></textarea></div>
        <div class="field"><label class="field-label">טקסט היכרות</label><textarea id="hero.lead_2"></textarea></div>
        <div class="fields-row"><div class="field"><label class="field-label">ציטוט לקוח</label><input type="text" id="hero.quote"></div><div class="field"><label class="field-label">שם המצטט</label><input type="text" id="hero.quote_attr"></div></div>
      </div>
    </div>
    <div class="section-block" id="block-pain">
      <div class="section-head" onclick="toggleBlock('pain')"><div class="section-head-left"><div class="section-icon">😟</div><div><div class="section-name">כאבים</div><div class="section-count">כותרת, 4 כרטיסים, ציטוט</div></div></div><div class="chevron">▼</div></div>
      <div class="section-body">
        <div class="field"><label class="field-label">כותרת ראשית</label><input type="text" id="pain.title"></div>
        <div class="fields-divider">כרטיס 1</div><div class="fields-row"><div class="field"><label class="field-label">כותרת</label><input type="text" id="pain.cards.0.title"></div><div class="field"><label class="field-label">תיאור</label><input type="text" id="pain.cards.0.desc"></div></div>
        <div class="fields-divider">כרטיס 2</div><div class="fields-row"><div class="field"><label class="field-label">כותרת</label><input type="text" id="pain.cards.1.title"></div><div class="field"><label class="field-label">תיאור</label><input type="text" id="pain.cards.1.desc"></div></div>
        <div class="fields-divider">כרטיס 3</div><div class="fields-row"><div class="field"><label class="field-label">כותרת</label><input type="text" id="pain.cards.2.title"></div><div class="field"><label class="field-label">תיאור</label><input type="text" id="pain.cards.2.desc"></div></div>
        <div class="fields-divider">כרטיס 4</div><div class="fields-row"><div class="field"><label class="field-label">כותרת</label><input type="text" id="pain.cards.3.title"></div><div class="field"><label class="field-label">תיאור</label><input type="text" id="pain.cards.3.desc"></div></div>
        <div class="fields-divider">ציטוט תחתון</div><div class="fields-row"><div class="field"><label class="field-label">ציטוט</label><input type="text" id="pain.quote"></div><div class="field"><label class="field-label">שם</label><input type="text" id="pain.quote_attr"></div></div>
      </div>
    </div>
    <div class="section-block" id="block-ws">
      <div class="section-head" onclick="toggleBlock('ws')"><div class="section-head-left"><div class="section-icon">🎓</div><div><div class="section-name">הדרכות</div><div class="section-count">4 הדרכות — כותרות ומחירים</div></div></div><div class="chevron">▼</div></div>
      <div class="section-body">
        <div class="fields-divider">הדרכה 1 — AI</div><div class="field"><label class="field-label">כותרת</label><input type="text" id="workshops.0.title"></div><div class="fields-row"><div class="field"><label class="field-label">מחיר</label><input type="text" id="workshops.0.price"></div><div class="field"><label class="field-label">תיאור מחיר</label><input type="text" id="workshops.0.price_label"></div></div>
        <div class="fields-divider">הדרכה 2 — קבצים</div><div class="field"><label class="field-label">כותרת</label><input type="text" id="workshops.1.title"></div><div class="fields-row"><div class="field"><label class="field-label">מחיר</label><input type="text" id="workshops.1.price"></div><div class="field"><label class="field-label">תיאור מחיר</label><input type="text" id="workshops.1.price_label"></div></div>
        <div class="fields-divider">הדרכה 3 — אבטחה</div><div class="field"><label class="field-label">כותרת</label><input type="text" id="workshops.2.title"></div><div class="fields-row"><div class="field"><label class="field-label">מחיר</label><input type="text" id="workshops.2.price"></div><div class="field"><label class="field-label">תיאור מחיר</label><input type="text" id="workshops.2.price_label"></div></div>
        <div class="fields-divider">הדרכה 4 — גוגל</div><div class="field"><label class="field-label">כותרת</label><input type="text" id="workshops.3.title"></div><div class="fields-row"><div class="field"><label class="field-label">מחיר</label><input type="text" id="workshops.3.price"></div><div class="field"><label class="field-label">תיאור מחיר</label><input type="text" id="workshops.3.price_label"></div></div>
      </div>
    </div>
    <div class="section-block" id="block-lecture">
      <div class="section-head" onclick="toggleBlock('lecture')"><div class="section-head-left"><div class="section-icon">🎤</div><div><div class="section-name">ההרצאה הבאה</div><div class="section-count">כותרת, תיאור, קישור, מחיר</div></div></div><div class="chevron">▼</div></div>
      <div class="section-body">
        <div class="fields-row"><div class="field"><label class="field-label">שם (badge)</label><input type="text" id="lecture.badge"></div><div class="field"><label class="field-label">כותרת ראשית</label><input type="text" id="lecture.title"></div></div>
        <div class="field"><label class="field-label">תיאור</label><textarea id="lecture.desc"></textarea></div>
        <div class="field"><label class="field-label">פרס / הטבה</label><input type="text" id="lecture.prize"></div>
        <div class="fields-row"><div class="field"><label class="field-label">מחיר כרטיס</label><input type="text" id="lecture.price"></div><div class="field"><label class="field-label">קישור לרישום</label><input type="text" id="lecture.url"></div></div>
      </div>
    </div>
    <div class="section-block" id="block-testi">
      <div class="section-head" onclick="toggleBlock('testi')"><div class="section-head-left"><div class="section-icon">💬</div><div><div class="section-name">המלצות</div><div class="section-count">ציטוט ראשי + 3 המלצות</div></div></div><div class="chevron">▼</div></div>
      <div class="section-body">
        <div class="fields-divider">ציטוט ראשי</div><div class="fields-row"><div class="field"><label class="field-label">ציטוט</label><textarea id="testimonials.featured_text"></textarea></div><div class="field"><label class="field-label">שם</label><input type="text" id="testimonials.featured_attr"></div></div>
        <div class="fields-divider">המלצה 1</div><div class="fields-row"><div class="field"><label class="field-label">טקסט</label><textarea id="testimonials.cards.0.text"></textarea></div><div class="field"><label class="field-label">שם</label><input type="text" id="testimonials.cards.0.name"></div></div>
        <div class="fields-divider">המלצה 2</div><div class="fields-row"><div class="field"><label class="field-label">טקסט</label><textarea id="testimonials.cards.1.text"></textarea></div><div class="field"><label class="field-label">שם</label><input type="text" id="testimonials.cards.1.name"></div></div>
        <div class="fields-divider">המלצה 3</div><div class="fields-row"><div class="field"><label class="field-label">טקסט</label><textarea id="testimonials.cards.2.text"></textarea></div><div class="field"><label class="field-label">שם</label><input type="text" id="testimonials.cards.2.name"></div></div>
      </div>
    </div>
    <div class="section-block" id="block-about">
      <div class="section-head" onclick="toggleBlock('about')"><div class="section-head-left"><div class="section-icon">👤</div><div><div class="section-name">מי אני</div><div class="section-count">כותרת, פסקאות, ציטוט</div></div></div><div class="chevron">▼</div></div>
      <div class="section-body">
        <div class="field"><label class="field-label">כותרת</label><input type="text" id="about.title"></div>
        <div class="field"><label class="field-label">פסקה 1</label><textarea id="about.p1"></textarea></div>
        <div class="field"><label class="field-label">פסקה 2</label><textarea id="about.p2"></textarea></div>
        <div class="field"><label class="field-label">פסקה 3</label><textarea id="about.p3"></textarea></div>
        <div class="field"><label class="field-label">פסקה 4</label><textarea id="about.p4"></textarea></div>
        <div class="field"><label class="field-label">פסקה 5</label><textarea id="about.p5"></textarea></div>
        <div class="field"><label class="field-label">ציטוט בכרטיס</label><textarea id="about.quote"></textarea></div>
      </div>
    </div>
  </div>

  <!-- TAB: CODE -->
  <div class="tab-panel" id="tab-code">
    <div class="status-bar">
      <div class="status-dot" id="status-dot-code"></div>
      <div class="status-text" id="status-text-code">טוען קבצים...</div>
      <button class="editor-btn" onclick="newFilePrompt()" style="background:var(--navy-light);color:var(--navy);font-size:0.75rem;padding:5px 14px;">📄 קובץ חדש</button>
      <button class="editor-btn" onclick="newFolderPrompt()" style="background:var(--navy-light);color:var(--navy);font-size:0.75rem;padding:5px 14px;">📁 תיקייה חדשה</button>
      <button class="editor-btn" onclick="loadFileTree(currentTreePath||'')" style="background:var(--cream);color:var(--text-mid);font-size:0.75rem;padding:5px 14px;">↻ רענן</button>
    </div>
    <div class="code-layout">
      <div class="file-list">
        <div class="file-list-title">קבצים ותיקיות</div>
        <div id="file-items"></div>
      </div>
      <div class="editor-wrap">
        <div class="editor-topbar">
          <div class="editor-filename" id="editor-filename">— בחר קובץ —</div>
          <div class="editor-actions">
            <button class="editor-btn" id="delete-file-btn" onclick="deleteFile()" style="background:#fee2e2;color:var(--red);display:none;">מחק</button>
            <button class="editor-btn" id="paste-publish-btn" onclick="pasteAndPublish()" disabled style="background:var(--navy);color:#fff;">📋 הדבק מהלוח ופרסם</button>
          </div>
        </div>
        <textarea id="code-editor" placeholder="בחר קובץ מהרשימה משמאל..."></textarea>
      </div>
    </div>
  </div>

  <!-- TAB: BACKUPS -->
  <div class="tab-panel" id="tab-backups">
    <div class="backups-header">
      <div class="backups-title">גיבויים</div>

    </div>
    <div class="status-bar">
      <div class="status-dot" id="status-dot-backup"></div>
      <div class="status-text" id="status-text-backup">טוען גיבויים...</div>
    </div>
    <div class="backup-list" id="backup-list"><div class="backup-empty">טוען...</div></div>
  </div>

</div>

<script src="/admin/admin-core.js"></script>
<script src="/admin/admin-content.js"></script>
<script src="/admin/admin-code.js"></script>
<script src="/admin/admin-backups.js"></script>
<script>checkToken();</script>
</body>
</html>
