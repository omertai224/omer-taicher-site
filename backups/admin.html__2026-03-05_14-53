<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>פאנל ניהול | עומר טייכר</title>
<link href="https://fonts.googleapis.com/css2?family=Rubik:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --navy:#1a4a6b; --navy-light:#eef4f8;
    --orange:#f6a67e; --orange-deep:#e8854a; --orange-light:#fdeede;
    --cream:#fdf8f2; --white:#fff; --border:#e8e0d6;
    --text:#1e1e1e; --text-mid:#555; --text-light:#999;
    --green:#22c55e; --red:#ef4444; --blue:#3b82f6;
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  body { font-family:'Rubik',sans-serif; background:var(--cream); color:var(--text); }

  /* TOKEN GATE */
  #token-gate { display:none; position:fixed; inset:0; background:var(--navy); z-index:9999; align-items:center; justify-content:center; flex-direction:column; gap:20px; padding:32px; }
  .token-box { background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.15); border-radius:16px; padding:32px; max-width:420px; width:100%; text-align:center; }
  .token-box h2 { font-size:1rem; color:#fff; font-weight:700; margin-bottom:8px; }
  .token-box p { font-size:0.82rem; color:rgba(255,255,255,0.5); margin-bottom:20px; }
  .token-input { width:100%; background:rgba(255,255,255,0.08); border:1.5px solid rgba(255,255,255,0.2); color:#fff; padding:12px 16px; border-radius:10px; font-family:'Rubik',sans-serif; font-size:0.9rem; outline:none; margin-bottom:14px; direction:ltr; text-align:left; }
  .token-btn { width:100%; background:var(--orange-deep); color:#fff; border:none; padding:13px; border-radius:50px; font-family:'Rubik',sans-serif; font-size:0.95rem; font-weight:700; cursor:pointer; }

  /* HEADER */
  .header { background:var(--navy); padding:0 28px; display:flex; align-items:center; justify-content:space-between; position:sticky; top:0; z-index:100; box-shadow:0 2px 16px rgba(0,0,0,0.2); height:56px; }
  .header-logo { font-size:1rem; font-weight:800; color:#fff; }
  .header-logo span { color:var(--orange); }
  .header-right { display:flex; align-items:center; gap:10px; }

  /* TABS */
  .tabs { display:flex; gap:4px; background:rgba(255,255,255,0.08); border-radius:50px; padding:4px; }
  .tab-btn { padding:7px 18px; border-radius:50px; border:none; background:transparent; color:rgba(255,255,255,0.6); font-family:'Rubik',sans-serif; font-size:0.82rem; font-weight:600; cursor:pointer; transition:all 0.2s; white-space:nowrap; }
  .tab-btn.active { background:var(--orange-deep); color:#fff; }

  .repo-switcher { position:relative; }
  .repo-current { display:flex; align-items:center; gap:8px; background:rgba(255,255,255,0.1); border:1px solid rgba(255,255,255,0.2); color:#fff; padding:8px 16px; border-radius:50px; font-family:'Rubik',sans-serif; font-size:0.78rem; font-weight:700; cursor:pointer; transition:all 0.2s; white-space:nowrap; }
  .repo-current:hover { background:rgba(255,255,255,0.18); }
  .repo-dropdown { display:none; position:absolute; top:calc(100% + 8px); left:0; background:var(--white); border:1px solid var(--border); border-radius:12px; overflow:hidden; box-shadow:0 8px 24px rgba(0,0,0,0.15); min-width:160px; z-index:200; }
  .repo-dropdown.open { display:block; }
  .repo-option { padding:11px 16px; font-size:0.85rem; font-weight:600; color:var(--text); cursor:pointer; transition:background 0.15s; white-space:nowrap; }
  .repo-option:hover { background:var(--orange-light); color:var(--orange-deep); }
  .repo-option.active { background:var(--navy); color:#fff; }

  /* SAVE BTN */
  .save-btn { background:var(--orange-deep); color:#fff; border:none; padding:8px 20px; border-radius:50px; font-family:'Rubik',sans-serif; font-size:0.82rem; font-weight:700; cursor:pointer; transition:all 0.2s; display:flex; align-items:center; gap:6px; white-space:nowrap; }
  .save-btn:hover { background:#fff; color:var(--navy); }
  .save-btn:disabled { opacity:0.4; cursor:not-allowed; }

  /* STATUS */
  .status-bar { background:var(--white); border:1px solid var(--border); border-radius:14px; padding:12px 18px; margin-bottom:24px; display:flex; align-items:center; gap:10px; font-size:0.83rem; }
  .status-dot { width:8px; height:8px; border-radius:50%; background:var(--text-light); flex-shrink:0; }
  .status-dot.ok { background:var(--green); }
  .status-dot.loading { background:var(--orange); animation:blink 1s infinite; }
  .status-dot.error { background:var(--red); }
  .status-text { color:var(--text-mid); flex:1; }
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.3} }

  /* MAIN */
  #main-content { display:none; }
  .tab-panel { display:none; max-width:900px; margin:0 auto; padding:28px 20px 80px; }
  .tab-panel.active { display:block; }

  /* ===== TAB 1: CONTENT ===== */
  .section-block { background:var(--white); border:1px solid var(--border); border-radius:16px; margin-bottom:12px; overflow:hidden; }
  .section-head { padding:16px 20px; display:flex; align-items:center; justify-content:space-between; cursor:pointer; user-select:none; transition:background 0.15s; }
  .section-head:hover { background:var(--cream); }
  .section-head-left { display:flex; align-items:center; gap:12px; }
  .section-icon { width:34px; height:34px; background:var(--orange-light); border-radius:10px; display:flex; align-items:center; justify-content:center; font-size:0.95rem; }
  .section-name { font-size:0.92rem; font-weight:700; color:var(--navy); }
  .section-count { font-size:0.7rem; color:var(--text-light); margin-top:2px; }
  .chevron { color:var(--text-light); font-size:0.8rem; transition:transform 0.25s; }
  .section-block.open .chevron { transform:rotate(180deg); }
  .section-body { display:none; padding:0 20px 20px; border-top:1px solid var(--border); }
  .section-block.open .section-body { display:block; }
  .field { margin-top:16px; }
  .field-label { font-size:0.7rem; font-weight:700; color:var(--text-mid); margin-bottom:5px; text-transform:uppercase; letter-spacing:0.5px; display:block; }
  .field input, .field textarea { width:100%; background:var(--cream); border:1.5px solid var(--border); border-radius:10px; padding:9px 13px; font-family:'Rubik',sans-serif; font-size:0.88rem; color:var(--text); outline:none; transition:border-color 0.2s; resize:vertical; }
  .field input:focus, .field textarea:focus { border-color:var(--orange-deep); background:var(--white); }
  .field textarea { min-height:75px; line-height:1.6; }
  .fields-row { display:grid; grid-template-columns:1fr 1fr; gap:12px; }
  @media (max-width:600px) { .fields-row { grid-template-columns:1fr; } }
  .fields-divider { margin:18px 0 0; padding-top:16px; border-top:1px dashed var(--border); font-size:0.7rem; font-weight:700; color:var(--text-light); text-transform:uppercase; letter-spacing:0.5px; }

  /* ===== TAB 2: CODE EDITOR ===== */
  .code-layout { display:grid; grid-template-columns:200px 1fr; gap:16px; height: calc(100vh - 200px); }
  .file-list { background:var(--white); border:1px solid var(--border); border-radius:14px; overflow:hidden; }
  .file-list-title { padding:14px 16px; font-size:0.72rem; font-weight:700; color:var(--text-light); text-transform:uppercase; letter-spacing:0.5px; border-bottom:1px solid var(--border); }
  .file-item { padding:12px 16px; cursor:pointer; display:flex; align-items:center; gap:10px; transition:background 0.15s; border-bottom:1px solid var(--border); font-size:0.85rem; color:var(--text-mid); font-weight:500; }
  .file-item:hover { background:var(--cream); }
  .file-item.active { background:var(--orange-light); color:var(--orange-deep); font-weight:700; }
  .file-item-icon { font-size:0.9rem; }
  .editor-wrap { background:var(--white); border:1px solid var(--border); border-radius:14px; overflow:hidden; display:flex; flex-direction:column; }
  .editor-topbar { padding:12px 18px; border-bottom:1px solid var(--border); display:flex; align-items:center; justify-content:space-between; background:var(--cream); }
  .editor-filename { font-size:0.85rem; font-weight:700; color:var(--navy); font-family:monospace; }
  .editor-actions { display:flex; gap:8px; }
  .editor-btn { padding:6px 16px; border-radius:50px; border:none; font-family:'Rubik',sans-serif; font-size:0.78rem; font-weight:700; cursor:pointer; transition:all 0.2s; }
  .editor-btn-save { background:var(--orange-deep); color:#fff; }
  .editor-btn-save:hover { background:var(--navy); }
  .editor-btn-save:disabled { opacity:0.4; cursor:not-allowed; }
  #code-editor { flex:1; width:100%; border:none; outline:none; padding:18px; font-family:'Courier New', monospace; font-size:0.82rem; line-height:1.7; resize:none; background:#1e1e2e; color:#cdd6f4; tab-size:2; }

  /* ===== TAB 3: BACKUPS ===== */
  .backups-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:20px; }
  .backups-title { font-size:1.1rem; font-weight:800; color:var(--navy); }
  .backup-now-btn { background:var(--navy); color:#fff; border:none; padding:10px 22px; border-radius:50px; font-family:'Rubik',sans-serif; font-size:0.82rem; font-weight:700; cursor:pointer; transition:all 0.2s; display:flex; align-items:center; gap:8px; }
  .backup-now-btn:hover { background:var(--orange-deep); }
  .backup-list { display:flex; flex-direction:column; gap:10px; }
  .backup-item { background:var(--white); border:1px solid var(--border); border-radius:14px; padding:16px 20px; display:flex; align-items:center; justify-content:space-between; }
  .backup-info { display:flex; flex-direction:column; gap:4px; }
  .backup-name { font-size:0.88rem; font-weight:700; color:var(--navy); font-family:monospace; }
  .backup-date { font-size:0.72rem; color:var(--text-light); }
  .backup-actions { display:flex; gap:8px; }
  .restore-btn { background:var(--navy-light); color:var(--navy); border:none; padding:7px 16px; border-radius:50px; font-family:'Rubik',sans-serif; font-size:0.78rem; font-weight:700; cursor:pointer; transition:all 0.2s; }
  .restore-btn:hover { background:var(--navy); color:#fff; }
  .backup-empty { text-align:center; padding:60px 20px; color:var(--text-light); font-size:0.88rem; }
</style>
</head>
<body>

<!-- TOKEN GATE -->
<div id="token-gate">
  <div style="font-size:1.3rem; font-weight:800; color:#fff; font-family:'Rubik',sans-serif;">עומר <span style="color:var(--orange)">טייכר</span> — פאנל ניהול</div>
  <div class="token-box">
    <h2>הכנס GitHub Token</h2>
    <p>נשמר אצלך במכשיר בלבד</p>
    <input type="text" name="username" autocomplete="username" value="admin" style="display:none;">
    <input class="token-input" id="token-input" type="password" placeholder="ghp_..." autocomplete="current-password" onkeydown="if(event.key==='Enter')saveToken()">
    <button class="token-btn" onclick="saveToken()">כניסה</button>
  </div>
</div>

<!-- MAIN -->
<div id="main-content">

  <div class="header">
    <div class="header-logo">עומר <span>טייכר</span></div>
    <div class="header-right">
      <div class="tabs" style="margin-left:0">
        <button class="tab-btn active" onclick="switchTab('content')">📝 תוכן</button>
        <button class="tab-btn" onclick="switchTab('code')">💻 קוד</button>
        <button class="tab-btn" onclick="switchTab('backups')">🔄 גיבויים</button>
      </div>
      <div class="repo-switcher" id="repo-switcher">
        <div class="repo-current" onclick="toggleRepoDropdown()">
          <span id="repo-label">🌐 אתר ראשי</span>
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
        </div>
        <div class="repo-dropdown" id="repo-dropdown">
          <div class="repo-option active" onclick="selectRepo('omer-taicher-site','🌐 אתר ראשי')">🌐 אתר ראשי</div>
          <div class="repo-option" onclick="selectRepo('omer-taicher-tutorials','🎓 הדרכות')">🎓 הדרכות</div>
        </div>
      </div>
      <button class="save-btn" id="save-content-btn" onclick="saveContent()" disabled>
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
        שמור ופרסם
      </button>
    </div>
  </div>

  <!-- TAB: CONTENT -->
  <div class="tab-panel active" id="tab-content">
    <div class="status-bar">
      <div class="status-dot loading" id="status-dot-content"></div>
      <div class="status-text" id="status-text-content">טוען תוכן...</div>
    </div>

    <!-- HERO -->
    <div class="section-block open" id="block-hero">
      <div class="section-head" onclick="toggleBlock('hero')">
        <div class="section-head-left"><div class="section-icon">🏠</div><div><div class="section-name">הירו</div><div class="section-count">כותרת, טקסט, ציטוט</div></div></div>
        <div class="chevron">▼</div>
      </div>
      <div class="section-body">
        <div class="fields-row">
          <div class="field"><label class="field-label">כותרת שורה 1</label><input type="text" id="hero.title_1"></div>
          <div class="field"><label class="field-label">כותרת שורה 2</label><input type="text" id="hero.title_2"></div>
        </div>
        <div class="field"><label class="field-label">טקסט פתיחה</label><textarea id="hero.lead_1"></textarea></div>
        <div class="field"><label class="field-label">טקסט היכרות</label><textarea id="hero.lead_2"></textarea></div>
        <div class="fields-row">
          <div class="field"><label class="field-label">ציטוט לקוח</label><input type="text" id="hero.quote"></div>
          <div class="field"><label class="field-label">שם המצטט</label><input type="text" id="hero.quote_attr"></div>
        </div>
      </div>
    </div>

    <!-- PAIN -->
    <div class="section-block" id="block-pain">
      <div class="section-head" onclick="toggleBlock('pain')">
        <div class="section-head-left"><div class="section-icon">😟</div><div><div class="section-name">כאבים</div><div class="section-count">כותרת, 4 כרטיסים, ציטוט</div></div></div>
        <div class="chevron">▼</div>
      </div>
      <div class="section-body">
        <div class="field"><label class="field-label">כותרת ראשית</label><input type="text" id="pain.title"></div>
        <div class="fields-divider">כרטיס 1</div>
        <div class="fields-row"><div class="field"><label class="field-label">כותרת</label><input type="text" id="pain.cards.0.title"></div><div class="field"><label class="field-label">תיאור</label><input type="text" id="pain.cards.0.desc"></div></div>
        <div class="fields-divider">כרטיס 2</div>
        <div class="fields-row"><div class="field"><label class="field-label">כותרת</label><input type="text" id="pain.cards.1.title"></div><div class="field"><label class="field-label">תיאור</label><input type="text" id="pain.cards.1.desc"></div></div>
        <div class="fields-divider">כרטיס 3</div>
        <div class="fields-row"><div class="field"><label class="field-label">כותרת</label><input type="text" id="pain.cards.2.title"></div><div class="field"><label class="field-label">תיאור</label><input type="text" id="pain.cards.2.desc"></div></div>
        <div class="fields-divider">כרטיס 4</div>
        <div class="fields-row"><div class="field"><label class="field-label">כותרת</label><input type="text" id="pain.cards.3.title"></div><div class="field"><label class="field-label">תיאור</label><input type="text" id="pain.cards.3.desc"></div></div>
        <div class="fields-divider">ציטוט תחתון</div>
        <div class="fields-row"><div class="field"><label class="field-label">ציטוט</label><input type="text" id="pain.quote"></div><div class="field"><label class="field-label">שם</label><input type="text" id="pain.quote_attr"></div></div>
      </div>
    </div>

    <!-- WORKSHOPS -->
    <div class="section-block" id="block-ws">
      <div class="section-head" onclick="toggleBlock('ws')">
        <div class="section-head-left"><div class="section-icon">🎓</div><div><div class="section-name">הדרכות</div><div class="section-count">4 הדרכות — כותרות ומחירים</div></div></div>
        <div class="chevron">▼</div>
      </div>
      <div class="section-body">
        <div class="fields-divider">הדרכה 1 — AI</div>
        <div class="field"><label class="field-label">כותרת</label><input type="text" id="workshops.0.title"></div>
        <div class="fields-row"><div class="field"><label class="field-label">מחיר</label><input type="text" id="workshops.0.price"></div><div class="field"><label class="field-label">תיאור מחיר</label><input type="text" id="workshops.0.price_label"></div></div>
        <div class="fields-divider">הדרכה 2 — קבצים</div>
        <div class="field"><label class="field-label">כותרת</label><input type="text" id="workshops.1.title"></div>
        <div class="fields-row"><div class="field"><label class="field-label">מחיר</label><input type="text" id="workshops.1.price"></div><div class="field"><label class="field-label">תיאור מחיר</label><input type="text" id="workshops.1.price_label"></div></div>
        <div class="fields-divider">הדרכה 3 — אבטחה</div>
        <div class="field"><label class="field-label">כותרת</label><input type="text" id="workshops.2.title"></div>
        <div class="fields-row"><div class="field"><label class="field-label">מחיר</label><input type="text" id="workshops.2.price"></div><div class="field"><label class="field-label">תיאור מחיר</label><input type="text" id="workshops.2.price_label"></div></div>
        <div class="fields-divider">הדרכה 4 — גוגל</div>
        <div class="field"><label class="field-label">כותרת</label><input type="text" id="workshops.3.title"></div>
        <div class="fields-row"><div class="field"><label class="field-label">מחיר</label><input type="text" id="workshops.3.price"></div><div class="field"><label class="field-label">תיאור מחיר</label><input type="text" id="workshops.3.price_label"></div></div>
      </div>
    </div>

    <!-- LECTURE -->
    <div class="section-block" id="block-lecture">
      <div class="section-head" onclick="toggleBlock('lecture')">
        <div class="section-head-left"><div class="section-icon">🎤</div><div><div class="section-name">ההרצאה הבאה</div><div class="section-count">כותרת, תיאור, קישור, מחיר</div></div></div>
        <div class="chevron">▼</div>
      </div>
      <div class="section-body">
        <div class="fields-row">
          <div class="field"><label class="field-label">שם (badge)</label><input type="text" id="lecture.badge"></div>
          <div class="field"><label class="field-label">כותרת ראשית</label><input type="text" id="lecture.title"></div>
        </div>
        <div class="field"><label class="field-label">תיאור</label><textarea id="lecture.desc"></textarea></div>
        <div class="field"><label class="field-label">פרס / הטבה</label><input type="text" id="lecture.prize"></div>
        <div class="fields-row">
          <div class="field"><label class="field-label">מחיר כרטיס</label><input type="text" id="lecture.price"></div>
          <div class="field"><label class="field-label">קישור לרישום</label><input type="text" id="lecture.url"></div>
        </div>
      </div>
    </div>

    <!-- TESTIMONIALS -->
    <div class="section-block" id="block-testi">
      <div class="section-head" onclick="toggleBlock('testi')">
        <div class="section-head-left"><div class="section-icon">💬</div><div><div class="section-name">המלצות</div><div class="section-count">ציטוט ראשי + 3 המלצות</div></div></div>
        <div class="chevron">▼</div>
      </div>
      <div class="section-body">
        <div class="fields-divider">ציטוט ראשי</div>
        <div class="fields-row"><div class="field"><label class="field-label">ציטוט</label><textarea id="testimonials.featured_text"></textarea></div><div class="field"><label class="field-label">שם</label><input type="text" id="testimonials.featured_attr"></div></div>
        <div class="fields-divider">המלצה 1</div>
        <div class="fields-row"><div class="field"><label class="field-label">טקסט</label><textarea id="testimonials.cards.0.text"></textarea></div><div class="field"><label class="field-label">שם</label><input type="text" id="testimonials.cards.0.name"></div></div>
        <div class="fields-divider">המלצה 2</div>
        <div class="fields-row"><div class="field"><label class="field-label">טקסט</label><textarea id="testimonials.cards.1.text"></textarea></div><div class="field"><label class="field-label">שם</label><input type="text" id="testimonials.cards.1.name"></div></div>
        <div class="fields-divider">המלצה 3</div>
        <div class="fields-row"><div class="field"><label class="field-label">טקסט</label><textarea id="testimonials.cards.2.text"></textarea></div><div class="field"><label class="field-label">שם</label><input type="text" id="testimonials.cards.2.name"></div></div>
      </div>
    </div>

    <!-- ABOUT -->
    <div class="section-block" id="block-about">
      <div class="section-head" onclick="toggleBlock('about')">
        <div class="section-head-left"><div class="section-icon">👤</div><div><div class="section-name">מי אני</div><div class="section-count">כותרת, פסקאות, ציטוט</div></div></div>
        <div class="chevron">▼</div>
      </div>
      <div class="section-body">
        <div class="field"><label class="field-label">כותרת</label><input type="text" id="about.title"></div>
        <div class="field"><label class="field-label">פסקה 1</label><textarea id="about.p1"></textarea></div>
