      "html": "<style>\n@keyframes fadeInDown{from{opacity:0;transform:translateY(-30px);}to{opacity:1;transform:translateY(0);}}\n@keyframes fadeInUp{from{opacity:0;transform:translateY(30px);}to{opacity:1;transform:translateY(0);}}\n@keyframes shimmer{0%{background-position:200% center;}100%{background-position:-200% center;}}\n.intro-wrap{display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:calc(100vh - 80px);background:#1a1a2e;text-align:center;padding:clamp(12px,2vh,20px) clamp(16px,3vw,40px) clamp(12px,2vh,20px);box-sizing:border-box;overflow-y:auto;}\n.intro-badge{background:linear-gradient(135deg,#3d5a80,#1e3050);color:white;padding:clamp(3px,0.5vh,5px) clamp(10px,1.5vw,16px);border-radius:50px;font-size:clamp(10px,1.2vw,12px);letter-spacing:2px;animation:fadeInDown .8s ease both;margin-bottom:clamp(6px,1vh,12px);}\n.intro-title{font-size:clamp(18px,3.5vw,46px);font-weight:900;color:white;line-height:1.15;animation:fadeInDown .9s ease .2s both;margin-bottom:clamp(4px,0.8vh,8px);}\n.intro-title span{background:linear-gradient(90deg,#f6a67e,#ff6b6b,#f6a67e);background-size:200% auto;-webkit-background-clip:text;-webkit-text-fill-color:transparent;animation:shimmer 3s linear infinite;}\n.intro-subtitle{font-size:clamp(11px,1.5vw,18px);color:#ffffffaa;animation:fadeInDown 1s ease .4s both;margin-bottom:clamp(2px,0.5vh,4px);line-height:1.5;}\n.intro-author{font-size:clamp(10px,1.1vw,13px);color:#ffffff66;animation:fadeInDown 1s ease .5s both;margin-bottom:clamp(10px,1.5vh,20px);}\n.intro-cards{display:flex;gap:clamp(8px,1vw,12px);flex-wrap:wrap;justify-content:center;animation:fadeInUp 1s ease .6s both;margin-bottom:clamp(10px,1.5vh,20px);}\n.intro-card{background:#ffffff12;border:1px solid #ffffff22;border-radius:clamp(10px,1vw,14px);padding:clamp(8px,1vh,12px) clamp(12px,1.5vw,18px);min-width:clamp(100px,12vw,130px);max-width:170px;}\n.intro-card .icon{font-size:24px;margin-bottom:clamp(2px,0.5vh,6px);}\n.intro-card .icon svg{width:clamp(20px,2.5vw,28px);height:clamp(20px,2.5vw,28px);}\n.intro-card .label{color:#ffffffcc;font-size:clamp(10px,1.1vw,12px);line-height:1.3;}\n.intro-btn{background:linear-gradient(135deg,#f6a67e,#e8834e);color:white;border:2px solid white;padding:clamp(8px,1.2vh,14px) clamp(24px,3vw,36px);border-radius:50px;font-size:clamp(12px,1.3vw,15px);font-weight:700;cursor:pointer;font-family:Rubik,sans-serif;box-shadow:0 6px 20px rgba(246,166,126,0.4);animation:fadeInUp 1s ease .8s both;}\n</style>\n<div class=\"intro-wrap\">\n<div class=\"intro-badge\">חינמי. מהיר. חיוני.</div>\n<div class=\"intro-title\">לא מוצאים קובץ במחשב?<br><span>Everything מוצא הכל תוך שנייה</span></div>\n<div class=\"intro-subtitle\">חיפוש מיידי בכל הקבצים במחשב שלכם.<br>במקום לחכות דקות לחיפוש של Windows -<br>Everything מוצא בפחות משנייה.</div>\n<div class=\"intro-author\">עומר טייכר · מדריך וטכנאי מחשבים</div>\n<div class=\"intro-cards\">\n<div class=\"intro-card\"><div class=\"icon\"><svg width=\"28\" height=\"28\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#f6a67e\" stroke-width=\"2\"><circle cx=\"11\" cy=\"11\" r=\"8\"/><line x1=\"21\" y1=\"21\" x2=\"16.65\" y2=\"16.65\"/></svg></div><div class=\"label\">חיפוש מיידי בכל הקבצים</div></div>\n<div class=\"intro-card\"><div class=\"icon\"><svg width=\"28\" height=\"28\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#f6a67e\" stroke-width=\"2\"><path d=\"M13 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V9z\"/><polyline points=\"13 2 13 9 20 9\"/></svg></div><div class=\"label\">מוצא כל קובץ, תיקייה, תמונה</div></div>\n<div class=\"intro-card\"><div class=\"icon\"><svg width=\"28\" height=\"28\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#f6a67e\" stroke-width=\"2\"><polyline points=\"13 17 18 12 13 7\"/><polyline points=\"6 17 11 12 6 7\"/></svg></div><div class=\"label\">מהיר פי אלף מחיפוש Windows</div></div>\n</div>\n<button class=\"intro-btn\" onclick=\"nextSlide(1)\">&#9654;&nbsp;&nbsp;בואו נתחיל</button>\n</div>"
