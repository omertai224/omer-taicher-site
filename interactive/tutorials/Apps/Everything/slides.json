      "html": "<style>\n.parta-wrap{display:flex;flex-direction:column;align-items:center;justify-content:center;height:calc(100vh - 80px);background:linear-gradient(135deg,#1a1a2e 0%,#16213e 100%);text-align:center;padding:32px;box-sizing:border-box;gap:24px;}\n.parta-badge{background:linear-gradient(135deg,#1a2540,#5b8fa8);color:white;padding:4px 16px;border-radius:50px;font-size:11px;letter-spacing:2px;display:inline-block;}\n.parta-title{font-size:clamp(20px,2.8vw,38px);font-weight:900;color:white;line-height:1.2;}\n.parta-title span{color:#f6a67e;}\n.parta-sub{color:#ffffffaa;font-size:clamp(13px,1.2vw,16px);line-height:1.6;}\n.parta-dl-btn{background:linear-gradient(135deg,#1a2540,#3d5a80);color:white;border:2px solid white;padding:18px 48px;border-radius:50px;font-size:clamp(16px,1.6vw,22px);font-weight:700;cursor:pointer;font-family:Rubik,sans-serif;display:inline-flex;align-items:center;gap:12px;text-decoration:none;transition:transform 0.2s,opacity 0.2s;}\n.parta-dl-btn:hover{opacity:0.9;transform:scale(1.03);}\n.parta-dl-version{color:#ffffff55;font-size:12px;}\n.parta-note{background:#f6a67e18;border:1px solid #f6a67e55;border-radius:12px;padding:12px 24px;max-width:460px;}\n.parta-note p{color:#ffffffcc;font-size:13px;margin:0;line-height:1.6;}\n.parta-note span{color:#f6a67e;font-weight:700;}\n</style>\n<div class=\"parta-wrap\">\n  <div class=\"parta-badge\">חלק א &middot; הורדה והתקנה</div>\n  <div class=\"parta-title\">קודם כל <span>הורידו את Everything</span></div>\n  <div class=\"parta-sub\">הקובץ יורד ישירות למחשב שלכם.<br>לאחר ההורדה חוזרים להדרכה וממשיכים לשלב הבא.</div>\n  <a class=\"parta-dl-btn\" href=\"https://github.com/omertai224/omer-taicher-site/releases/download/everythingv1/Everything.exe\" download>\n    <svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"white\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4\"/><polyline points=\"7 10