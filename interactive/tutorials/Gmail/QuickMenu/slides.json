     "textPos": {"left": "5%", "top": "30%"}, "textWidth": "300px"},

    {"index": 5, "step": 6, "type": "view", "image": "QuickMenu-06.png",
     "text": "<span style=\"color:#f6a67e;\">העברה כקובץ מצורף</span><br>שליחת ההודעה המקורית כקובץ מצורף בתוך מייל חדש. שימושי כשרוצים לשמור את הפורמט המקורי.<div style=\"text-align:center;margin-top:12px;\">לחצו על <span onclick=\"nextSlide()\" style=\"display:inline-flex;align-items:center;justify-content:center;width:36px;height:36px;background:linear-gradient(135deg,#1a2540,#3d5a80);border:2px solid white;border-radius:50%;cursor:pointer;vertical-align:middle;margin:0 6px;box-shadow:0 4px 12px rgba(26,37,64,0.5);\"><svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"white\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"9 18 15 12 9 6\"/></svg></span> כדי להמשיך.</div>",
     "textPos": {"left": "5%", "top": "30%"}, "textWidth": "310px"},

