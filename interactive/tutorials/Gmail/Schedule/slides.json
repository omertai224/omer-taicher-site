  "slides": [
    {
      "index": 0,
      "type": "intro",
      "html": "<style>.intro-wrap{display:flex;flex-direction:column;align-items:center;justify-content:center;height:calc(100vh - 80px);background:linear-gradient(135deg,#0f1a2e 0%,#1a2540 50%,#1e3050 100%);text-align:center;padding:40px 20px;}.intro-title{font-size:clamp(28px,4vw,42px);font-weight:900;color:#fff;margin-bottom:12px;line-height:1.3;}.intro-title span{color:#f6a67e;}.intro-desc{font-size:1rem;color:#ffffffaa;line-height:1.8;max-width:500px;margin-bottom:30px;}.intro-btn{background:linear-gradient(135deg,#f6a67e,#e8834e);color:white;border:2px solid white;padding:14px 36px;border-radius:50px;font-size:15px;font-weight:700;cursor:pointer;font-family:Rubik,sans-serif;box-shadow:0 6px 20px rgba(246,166,126,0.4);}.intro-btn:hover{transform:scale(1.05);}</style><div class=\"intro-wrap\"><div style=\"margin-bottom:20px;\"><svg width=\"48\" height=\"48\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#f6a67e\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"12\" cy=\"12\" r=\"10\"/><polyline points=\"12 6 12 12 16 14\"/></svg></div><div style=\"font-size:0.85rem;color:#f6a67e;font-weight:700;letter-spacing:1px;margin-bottom:8px;\">Gmail</div><div class=\"intro-title\">תזמון <span>שליחה</span></div><div class=\"intro-desc\">כתבתם מייל ב-11 בלילה?<br>לא חייבים שהלקוח ידע.<br>למדו לתזמן שליחה לכל שעה שתרצו.</div><button class=\"intro-btn\" onclick=\"nextSlide()\">בואו נתחיל</button></div>"
    },
    {
      "index": 1,
      "type": "special",
      "specialType": "howto",
      "html": "<style>.howto-wrap{display:flex;flex-direction:column;align-items:center;justify-content:center;height:calc(100vh - 80px);background:linear-gradient(135deg,#0f1a2e,#1a2540);text-align:center;padding:40px 20px;}.howto-title{font-size:1.4rem;font-weight:900;color:#fff;margin-bottom:20px;}.howto-desc{font-size:0.95rem;color:#ffffffaa;line-height:2;max-width:460px;margin-bottom:30px;}.howto-btn{background:linear-gradient(135deg,#1a2540,#3d5a80);color:white;border:2px solid white;padding:14px 36px;border-radius:50px;font-size:15px;font-weight:700;cursor:pointer;font-family:Rubik,sans-serif;box-shadow:0 4px 12px rgba(26,37,64,0.5);}</style><div class=\"howto-wrap\"><svg width=\"40\" height=\"40\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#f6a67e\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" style=\"margin-bottom:16px;\"><polygon points=\"5 3 19 12 5 21 5 3\"/></svg><div class=\"howto-title\">איך עובדים עם ההדרכה</div><div class=\"howto-desc\">בכל שקף תראו תמונה אמיתית מהמחשב.<br>לחצו על <span style=\"color:#f6a67e;font-weight:700;\">המסגרת הכתומה</span> כדי להתקדם.<br>בדיוק כמו שהייתם עושים במחשב שלכם.</div><button class=\"howto-btn\" onclick=\"nextSlide()\">הבנתי, קדימה</button></div>"
    },
    { "index": 2, "step": 1, "type": "click", "image": "Schedule-01.png", "text": "זהו המייל המתוזמן שלנו. רואים את התצוגה <span style=\"color:#f6a67e;\">in:scheduled</span>. לחצו על <span style=\"color:#f6a67e;\">ביטול השליחה</span> אם רוצים לבטל.", "box": { "top": "28%", "left": "2%", "right": "82%", "bottom": "65%" }, "textPos": { "left": "25%", "top": "35%" }, "textWidth": "280px" },
    { "index": 3, "step": 2, "type": "click", "image": "Schedule-02.png", "text": "כתבנו מייל ומוכנים לשלוח. במקום ללחוץ <span style=\"color:#f6a67e;\">שליחה</span>, לחצו על <span style=\"color:#f6a67e;\">החץ הקטן</span> שלידו. פה מתחבא הקסם.", "box": { "top": "90%", "left": "14%", "right": "80%", "bottom": "3%" }, "textPos": { "left": "25%", "top": "65%" }, "textWidth": "280px" },
    { "index": 4, "step": 3, "type": "click", "image": "Schedule-03.png", "text": "בתצוגת <span style=\"color:#f6a67e;\">in:scheduled</span> רואים את המייל שתוזמן. לחצו עליו כדי לצפות בתוכן.", "box": { "top": "25%", "left": "15%", "right": "50%", "bottom": "65%" }, "textPos": { "left": "25%", "top": "40%" }, "textWidth": "280px" },
    { "index": 5, "step": 4, "type": "click", "image": "Schedule-04.png", "text": "לחצו על <span style=\"color:#f6a67e;\">תזמון שליחה מתקדם</span> כדי לבחור בדיוק מתי לשלוח.", "box": { "top": "88%", "left": "10%", "right": "74%", "bottom": "5%" }, "textPos": { "left": "25%", "top": "65%" }, "textWidth": "260px" },
    { "index": 6, "step": 5, "type": "view", "image": "Schedule-05.png", "text": "המייל תוזמן בהצלחה! למטה מופיעה <span style=\"color:#f6a67e;\">הודעת אישור</span> עם השעה. אפשר ללחוץ X לסגירה.", "textPos": { "left": "25%", "top": "40%" }, "textWidth": "280px" },
    { "index": 7, "step": 6, "type": "click", "image": "Schedule-06.png", "text": "בואו נתזמן מייל נוסף. לחצו על <span style=\"color:#f6a67e;\">תזמון שליחה</span> ליד כפתור השליחה.", "box": { "top": "90%", "left": "12%", "right": "78%", "bottom": "3%" }, "textPos": { "left": "25%", "top": "65%" }, "textWidth": "260px" },
    { "index": 8, "step": 7, "type": "view", "image": "Schedule-07.png", "text": "מצוין! הודעה למטה: <span style=\"color:#f6a67e;\">השליחה תתבצע ל-9:00</span>. המייל תוזמן למחר בבוקר.", "textPos": { "left": "40%", "top": "70%" }, "textWidth": "260px" },
    { "index": 9, "step": 8, "type": "click", "image": "Schedule-08.png", "text": "רוצים תאריך ושעה מדויקים? לחצו על <span style=\"color:#f6a67e;\">בחירת תאריך ושעה</span>.", "box": { "top": "55%", "left": "20%", "right": "55%", "bottom": "35%" }, "textPos": { "left": "35%", "top": "30%" }, "textWidth": "260px" },
    { "index": 10, "step": 9, "type": "click", "image": "Schedule-09.png", "text": "לחצו על <span style=\"color:#f6a67e;\">תוויות</span> בצד כדי למצוא את ההודעות המתוזמנות.", "box": { "top": "20%", "left": "72%", "right": "8%", "bottom": "70%" }, "textPos": { "left": "40%", "top": "30%" }, "textWidth": "260px" },
    { "index": 11, "step": 10, "type": "click", "image": "Schedule-10.png", "text": "לחצו על <span style=\"color:#f6a67e;\">הודעות מתוזמנות</span> כדי לראות את כל המיילים שמחכים לשליחה.", "box": { "top": "35%", "left": "70%", "right": "5%", "bottom": "55%" }, "textPos": { "left": "35%", "top": "40%" }, "textWidth": "280px" },
    { "index": 12, "step": 11, "type": "click", "image": "Schedule-11.png", "text": "לחצו על <span style=\"color:#f6a67e;\">תזמון שליחה מתקדם</span> כדי לקבוע תאריך ושעה בדיוק.", "box": { "top": "88%", "left": "10%", "right": "74%", "bottom": "5%" }, "textPos": { "left": "25%", "top": "65%" }, "textWidth": "260px" },
    { "index": 13, "step": 12, "type": "click", "image": "Schedule-12.png", "text": "בחרו <span style=\"color:#f6a67e;\">תאריך</span> מלוח השנה, הגדירו <span style=\"color:#f6a67e;\">שעה</span>, ולחצו <span style=\"color:#f6a67e;\">תזמון שליחה</span>.", "box": { "top": "78%", "left": "12%", "right": "68%", "bottom": "12%" }, "textPos": { "left": "30%", "top": "30%" }, "textWidth": "280px" },
    { "index": 14, "step": 13, "type": "click", "image": "Schedule-13.png", "text": "לתזמון מהיר, לחצו על <span style=\"color:#f6a67e;\">מחר בצהריים</span>. ג'ימייל יגדיר הכל אוטומטית.", "box": { "top": "42%", "left": "20%", "right": "55%", "bottom": "50%" }, "textPos": { "left": "35%", "top": "25%" }, "textWidth": "260px" },
    { "index": 15, "step": 14, "type": "view", "image": "Schedule-14.png", "text": "המייל המתוזמן פתוח. למטה רואים הודעה כחולה עם אפשרות <span style=\"color:#f6a67e;\">ביטול</span>. תמיד אפשר לחזור בכם!", "textPos": { "left": "25%", "top": "50%" }, "textWidth": "280px" },
    { "index": 16, "step": 15, "type": "view", "image": "Schedule-15.png", "text": "טיפ: קיצור מקלדת <span style=\"color:#f6a67e;\">Ctrl+Enter</span> שולח מייל מיד. שימושי כשלא צריכים תזמון.", "textPos": { "left": "25%", "top": "65%" }, "textWidth": "260px" },
    { "index": 17, "step": 16, "type": "click", "image": "Schedule-16.png", "text": "לחצו על <span style=\"color:#f6a67e;\">דואר נכנס</span> כדי לחזור לתיבה הראשית.", "box": { "top": "15%", "left": "78%", "right": "5%", "bottom": "77%" }, "textPos": { "left": "45%", "top": "25%" }, "textWidth": "260px" },
    { "index": 18, "step": 17, "type": "click", "image": "Schedule-17.png", "text": "לחצו על <span style=\"color:#f6a67e;\">הודעות מתוזמנות</span> בתפריט הצד כדי לנהל את כל המיילים שתוזמנו.", "box": { "top": "45%", "left": "68%", "right": "5%", "bottom": "45%" }, "textPos": { "left": "35%", "top": "35%" }, "textWidth": "280px" },
    {
      "index": 19,
      "type": "special",
      "specialType": "finish",
      "html": "<style>.finish-wrap{display:flex;flex-direction:column;align-items:center;justify-content:center;height:calc(100vh - 80px);background:linear-gradient(135deg,#0f1a2e,#1a2540);text-align:center;padding:40px 20px;}.finish-title{font-size:1.6rem;font-weight:900;color:#fff;margin-bottom:16px;}.finish-desc{font-size:1rem;color:#ffffffaa;line-height:1.8;max-width:460px;}</style><div class=\"finish-wrap\"><svg width=\"48\" height=\"48\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#f6a67e\" stroke-width=\"1.5\" style=\"margin-bottom:16px;\"><circle cx=\"12\" cy=\"12\" r=\"10\"/><polyline points=\"12 6 12 12 16 14\"/></svg><div class=\"finish-title\">כל הכבוד!</div><div class=\"finish-desc\">עכשיו אתם יודעים לתזמן מיילים לכל שעה שתרצו.<br><br>לא עוד מיילים בשעה 11 בלילה.</div></div>"
    }
  ]
}
