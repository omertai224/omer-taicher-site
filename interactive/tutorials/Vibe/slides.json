      "html": "<style>\n.partb-wrap { display:flex; flex-direction:column; align-items:center; justify-content:center; height:calc(100vh - 80px); background:linear-gradient(135deg,#0f2a3a 0%,#1a4a6b 100%); text-align:center; padding:20px 40px; box-sizing:border-box; gap:10px; }\n.partb-check { width:56px; height:56px; background:linear-gradient(135deg,#1e5f74,#5b8fa8); border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto; }\n.partb-badge { background:#f6a67e22; border:1px solid #f6a67e55; color:#f6a67e; padding:3px 14px; border-radius:50px; font-size:11px; letter-spacing:2px; display:inline-block; }\n.partb-title { font-size:clamp(18px,2.8vw,36px); font-weight:900; color:white; margin-bottom:0; line-height:1.2; }\n.partb-title span { color:#f6a67e; }\n.partb-sub { color:#ffffffaa; font-size:14px; margin-bottom:0; }\n.partb-steps { display:flex; gap:10px; flex-wrap:wrap; justify-content:center; margin-bottom:0; }\n.partb-step { background:#ffffff0d; border:1px solid #ffffff22; border-radius:14px; padding:10px 16px; min-width:120px; max-width:160px; text-align:right; }\n.partb-step .ps-num { color:#5b8fa8; font-size:10px; font-weight:700; margin-bottom:2px; }\n.partb-step .ps-label { color:white; font-size:12px; font-weight:600; }\n.partb-btn { background:linear-gradient(135deg,#f6a67e,#ff6b6b); color:white; border:none; padding:11px 32px; border-radius:50px; font-size:15px; font-weight:700; cursor:pointer; font-family:Rubik,sans-serif; box-shadow:0 8px 32px rgba(246,166,126,0.4); }\n.partb-btn:hover { transform:scale(1.05); }\n</style>\n<div class=\"partb-wrap\">\n  <div class=\"partb-check\">\n    <svg width=\"40\" height=\"40\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"white\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg>\n  </div>\n  <div class=\"partb-badge\">חלק א הושלם</div>\n  <div class=\"partb-title\">עכשיו תורכם<br>הקטינו את החלון<br><span>והתקינו 